# SupaAgent Environment Configuration
# Copy this file to .env and fill in your values
# 
# IMPORTANT: Most secrets are now stored in Supabase Vault
# Only database connection and non-sensitive config should be in .env
# See: backend/lib/vault_secrets.py for vault integration

# =====================================================
# REQUIRED: Database Connection
# =====================================================
DATABASE_URL=postgresql://user:password@host:5432/database
# Or use Supabase format:
# POSTGRES_URL=postgresql://postgres.[project-ref]:password@aws-0-[region].pooler.supabase.com:6543/postgres

# =====================================================
# REQUIRED: Supabase Connection (for Vault access)
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =====================================================
# Non-Sensitive Configuration
# =====================================================

# Backend URL (for development)
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Twilio Phone Number (public, not secret)
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# LiveKit URL (public endpoint, not secret)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_LOCAL_URL=ws://localhost:7880

# S3/Storage Configuration (non-secret)
S3_BUCKET_NAME=your-bucket
S3_ENDPOINT=https://your-region.digitaloceanspaces.com
S3_REGION=your-region

# Google OAuth (Client ID is public)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Meta/WhatsApp (App ID is public, Verify Token is semi-public)
META_APP_ID=your-app-id
META_VERIFY_TOKEN=your-verify-token
NEXT_PUBLIC_META_VERIFY_TOKEN=your-verify-token

# Pinecone (Environment is public)
PINECONE_ENVIRONMENT=us-east-1

# Email From Address
EMAIL_FROM="SupaAgent <noreply@yourdomain.com>"

# =====================================================
# SECRETS - Stored in Supabase Vault
# Only keep these for local development fallback
# =====================================================
# AUTH_SECRET=your-jwt-secret
# OPENAI_API_KEY=sk-xxx
# STRIPE_SECRET_KEY=sk_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_ACCOUNT_SID=ACxxx
# LIVEKIT_API_KEY=xxx
# LIVEKIT_API_SECRET=xxx
# DEEPGRAM_API_KEY=xxx
# ELEVENLABS_API_KEY=xxx
# PINECONE_API_KEY=xxx
# GOOGLE_CLIENT_SECRET=xxx
# META_APP_SECRET=xxx
# ENCRYPTION_KEY=xxx
# S3_ACCESS_KEY=xxx
# S3_SECRET_KEY=xxx
# RESEND_API=xxx
# XAI_API_KEY=xxx

# =====================================================
# Stripe Price IDs (not secrets, just identifiers)
# =====================================================
STRIPE_PRICE_PRO_BASE=price_xxx
STRIPE_PRICE_PRO_PLUS_BASE=price_xxx
STRIPE_PRICE_PRO_MAX_BASE=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_xxx
